# 줄바꿈 / 텍스트 인코딩 / 언어 통계 제어. Windows 환경에서도 LF 강제 + 바이너리 안전성.

# 기본 — 자동 감지 후 LF 정규화
* text=auto eol=lf

# 명시적 텍스트 (확장자가 모호하지 않은 것)
*.java       text eol=lf
*.kt         text eol=lf
*.kts        text eol=lf
*.go         text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.bash       text eol=lf
*.zsh        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.sql        text eol=lf
*.tf         text eol=lf
*.tfvars     text eol=lf
*.hcl        text eol=lf
*.properties text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf

# Windows 전용 스크립트는 CRLF
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Gradle wrapper — 절대 변경 금지 (서명 / 무결성)
gradlew      text eol=lf
*/gradlew    text eol=lf
gradlew.bat  text eol=crlf
gradle/wrapper/gradle-wrapper.jar binary

# 바이너리
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        text
*.pdf        binary
*.zip        binary
*.tar        binary
*.tar.gz     binary
*.tgz        binary
*.jar        binary
*.war        binary
*.class      binary

# linguist — GitHub 언어 통계에서 제외 / 보정
# 자동 생성, 외부 라이브러리, vendored 코드 등은 통계에서 빼기
infrastructure/observability/grafana-dashboards/*.json linguist-generated=true
**/build/**     linguist-generated=true
**/.gradle/**   linguist-generated=true
docs/**         linguist-documentation=true

# diff hunk 헤더에 함수명 표시
*.java       diff=java
*.go         diff=golang
*.py         diff=python
*.css        diff=css
*.html       diff=html

# 머지 충돌 시 항상 유지/거절할 파일 (자동 생성 lock 등 — 현재는 없음. 필요시 추가)
# package-lock.json merge=ours
