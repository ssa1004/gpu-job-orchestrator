{
  "description": "GPU fleet 전체 / 노드별 사용 현황. DCGM exporter 가 수집한 메트릭 기반.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "Fleet Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Total GPUs",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "expr": "count(DCGM_FI_DEV_GPU_UTIL)", "legendFormat": "total" }
      ]
    },
    {
      "type": "stat",
      "title": "Avg utilization",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        { "expr": "avg(DCGM_FI_DEV_GPU_UTIL)", "legendFormat": "avg_util" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 30 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Idle GPUs (util < 10%)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        { "expr": "count(DCGM_FI_DEV_GPU_UTIL < 10)", "legendFormat": "idle" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "GPUs > 85°C",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "count(DCGM_FI_DEV_GPU_TEMP > 85)", "legendFormat": "hot" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Per-node",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "title": "GPU utilization by node",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "avg by (Hostname) (DCGM_FI_DEV_GPU_UTIL)",
          "legendFormat": "{{ Hostname }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "GPU memory usage",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE)",
          "legendFormat": "{{ Hostname }} gpu{{ gpu }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Temperature",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "{{ Hostname }} gpu{{ gpu }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "celsius" } }
    },
    {
      "type": "timeseries",
      "title": "XID errors (10m increase)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "increase(DCGM_FI_DEV_XID_ERRORS[10m])",
          "legendFormat": "{{ Hostname }} gpu{{ gpu }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Cost / Capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "Allocatable vs requested GPUs",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"nvidia_com_gpu\"})",
          "legendFormat": "allocatable"
        },
        {
          "expr": "sum(kube_pod_container_resource_requests{resource=\"nvidia_com_gpu\"})",
          "legendFormat": "requested"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gwp", "gpu", "dcgm"],
  "time": { "from": "now-3h", "to": "now" },
  "title": "GPU Fleet",
  "uid": "gwp-gpu-fleet",
  "version": 1
}
