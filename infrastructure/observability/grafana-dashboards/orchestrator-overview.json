{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(kube_deployment_status_replicas_updated{namespace=\"gwp\", deployment=\"orchestrator-api\"}[1m]) > 0",
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Deploys",
        "titleFormat": "Deploy"
      }
    ]
  },
  "description": "orchestrator-api 자체의 SLI / 운영 지표. SLO 정의는 docs/slo.md 참고.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "SLI Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Availability (5xx 제외율, 5m)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_server_requests_seconds_count{job=\"orchestrator-api\", status=~\"5..\", uri!~\"/actuator.*\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"orchestrator-api\", uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "POST /jobs p95 (5m)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"orchestrator-api\", uri=\"/api/v1/jobs\", method=\"POST\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Job 성공률 (1h)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(gwp_orchestrator_jobs_completed_total{status=\"succeeded\"}[1h])) / sum(rate(gwp_orchestrator_jobs_completed_total{status=~\"succeeded|failed\"}[1h]))",
          "legendFormat": "success_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Outbox p95 lag",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "gwp_orchestrator_outbox_publish_lag_seconds{quantile=\"0.95\"}",
          "legendFormat": "lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "API Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "title": "RPS by endpoint",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"orchestrator-api\", uri!~\"/actuator.*\"}[1m]))",
          "legendFormat": "{{ method }} {{ uri }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx rate by endpoint",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"orchestrator-api\", status=~\"5..\"}[1m]))",
          "legendFormat": "{{ uri }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles (POST /jobs)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"orchestrator-api\", uri=\"/api/v1/jobs\", method=\"POST\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"orchestrator-api\", uri=\"/api/v1/jobs\", method=\"POST\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"orchestrator-api\", uri=\"/api/v1/jobs\", method=\"POST\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP status mix",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"orchestrator-api\", uri!~\"/actuator.*\"}[1m]))",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Job Lifecycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "Submitted vs completed (per second)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "rate(gwp_orchestrator_jobs_submitted_total[1m])",
          "legendFormat": "submitted"
        },
        {
          "expr": "sum by (status) (rate(gwp_orchestrator_jobs_completed_total[1m]))",
          "legendFormat": "completed:{{ status }}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active jobs by status",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "sum by (status) (gwp_orchestrator_jobs_in_state)",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Outbox / Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },
    {
      "type": "timeseries",
      "title": "Outbox publish lag (p50/p95/p99)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "gwp_orchestrator_outbox_publish_lag_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "expr": "gwp_orchestrator_outbox_publish_lag_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95"
        },
        {
          "expr": "gwp_orchestrator_outbox_publish_lag_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Outbox pending count",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "gwp_orchestrator_outbox_pending_total",
          "legendFormat": "pending"
        }
      ]
    },
    {
      "type": "row",
      "title": "Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },
    {
      "type": "timeseries",
      "title": "HikariCP connections",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"orchestrator-api\"}",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"orchestrator-api\"}",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_max{application=\"orchestrator-api\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "targets": [
        {
          "expr": "sum by (pod) (jvm_memory_used_bytes{job=\"orchestrator-api\", area=\"heap\"})",
          "legendFormat": "{{ pod }} used"
        },
        {
          "expr": "sum by (pod) (jvm_memory_max_bytes{job=\"orchestrator-api\", area=\"heap\"})",
          "legendFormat": "{{ pod }} max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["gwp", "orchestrator-api", "slo"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "current": { "value": "gwp", "text": "gwp" }
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Orchestrator API — Overview",
  "uid": "gwp-orchestrator-overview",
  "version": 1
}
